  # ── Promote to External Testing ───────────────────────

  desc "Wait for TestFlight processing, distribute to External Testing"
  lane :promote_external do
    api_key_obj = api_key
    client = Spaceship::ConnectAPI.client
    app = Spaceship::ConnectAPI::App.find(app_id)
    UI.user_error!("App not found") if app.nil?

    build = _wait_for_valid_build(client, app)
    _promote_to_external(client, app, build)
  end

  # ── Full Deploy (used by store_deploy.sh) ─────────────

  desc "Full deploy: upload → wait for processing → External Testing → submit for review if needed"
  # ── TestFlight: Upload + Promote to External Testing ──

  desc "Upload to TestFlight and promote to External Testing"
  lane :deploy_external do
    upload_testflight

    client = Spaceship::ConnectAPI.client
    app = Spaceship::ConnectAPI::App.find(app_id)
    UI.user_error!("App not found") if app.nil?

    build = _wait_for_valid_build(client, app)
    _promote_to_external(client, app, build)
  end

  # ── App Store Review: Reject old + Submit new ──────────

  desc "Reject pending App Store version and submit latest build for review"
  lane :submit_for_review do
    api_key
    client = Spaceship::ConnectAPI.client
    app = Spaceship::ConnectAPI::App.find(app_id)
    UI.user_error!("App not found") if app.nil?

    build = _wait_for_valid_build(client, app)

    # 1. Reject any pending versions to unblock new submission
    _reject_pending_version(client, app)

    # 2. Submit the new version
    _submit_build_for_review(client, app, build)
    UI.success("App Store Review submission complete!")
  end

  # ── Expire & Promote (fix stuck beta review) ──────────

  desc "Expire previous builds, then promote latest to External Testing. Usage: fastlane expire_and_promote build_number:2026061904"
  lane :expire_and_promote do |options|
    api_key
    client = Spaceship::ConnectAPI.client
    app = Spaceship::ConnectAPI::App.find(app_id)
    UI.user_error!("App not found") if app.nil?

    target_version = options[:build_number]

    if target_version
      # Find specific build by version number.
      builds = client.get_builds(
        filter: { app: app.id, version: target_version },
        includes: Spaceship::ConnectAPI::Build::ESSENTIAL_INCLUDES
      ).to_models
      build = builds.first
      UI.user_error!("Build #{target_version} not found in App Store Connect") if build.nil?
    else
      build = _wait_for_valid_build(client, app)
    end

    UI.message("Target build: #{build.version} (#{build.processing_state})")

    # Wait for build to become VALID.
    unless build.processing_state == "VALID"
      build = _wait_for_valid_build(client, app)
    end

    _expire_previous_beta_builds(client, app, build.id)
    _promote_to_external(client, app, build)
    UI.success("Done! Build #{build.version} promoted to External Testing.")
  end

  # ── App Store Review Submission ───────────────────────

  desc "Submit latest build for App Store Review"
  lane :submit do
    submit_for_review
  end

  # ── Private Methods ───────────────────────────────────

  def _wait_for_valid_build(client, app)
    builds = client.get_builds(
      filter: { app: app.id },
      sort: "-uploadedDate", limit: 1,
      includes: Spaceship::ConnectAPI::Build::ESSENTIAL_INCLUDES
    ).to_models
    build = builds.first
    UI.user_error!("No builds found") if build.nil?
    UI.message("Latest build: #{build.version} (#{build.processing_state})")

    return build if build.processing_state == "VALID"

    UI.message("Build still processing, waiting...")
    40.times do |i|
      sleep(30)
      builds = client.get_builds(
        filter: { app: app.id },
        sort: "-uploadedDate", limit: 1,
        includes: Spaceship::ConnectAPI::Build::ESSENTIAL_INCLUDES
      ).to_models
      build = builds.first
      if build && build.processing_state == "VALID"
        UI.success("Build #{build.version} is VALID (after #{(i + 1) * 30}s)")
        return build
      end
      UI.message("  [#{i + 1}/40] Still #{build&.processing_state || 'unknown'}...")
    end
    UI.user_error!("Build did not become VALID in 20 minutes")
  end

  def _expire_previous_beta_builds(client, app, keep_build_id)
    # Find all builds for this app, sorted newest first.
    builds = client.get_builds(
      filter: { app: app.id },
      sort: "-uploadedDate", limit: 10,
      includes: Spaceship::ConnectAPI::Build::ESSENTIAL_INCLUDES
    ).to_models

    builds.each do |b|
      next if b.id == keep_build_id
      next if b.processing_state == "PROCESSING"

      # Check for active beta review submission on this build.
      beta_subs = client.get_beta_app_review_submissions(filter: { build: b.id }).to_models
      active_sub = beta_subs.find do |s|
        ["WAITING_FOR_REVIEW", "IN_REVIEW"].include?(s.beta_review_state)
      end

      if active_sub
        if active_sub.beta_review_state == "WAITING_FOR_REVIEW"
          UI.message("Cancelling beta review (#{active_sub.id}) for build #{b.version}...")
          begin
            client.delete_beta_app_review_submission(beta_app_review_submission_id: active_sub.id)
            UI.success("Cancelled beta review for build #{b.version}")
          rescue => e
            UI.message("Cancel beta review: #{e.message}")
          end
        else
          # IN_REVIEW — can't cancel, but we can still expire the build.
          UI.message("Build #{b.version} beta review is IN_REVIEW — cannot cancel, will expire build.")
        end
      end

      # Expire the build so it stops blocking the new one.
      if b.processing_state == "VALID"
        UI.message("Expiring build #{b.version}...")
        begin
          b.update(attributes: { expired: true })
          UI.success("Expired build #{b.version}")
        rescue => e
          UI.message("Expire build #{b.version}: #{e.message}")
        end
      end
    end
  end

  def _promote_to_external(client, app, build)
    groups = client.get_beta_groups(filter: { app: app.id }).to_models
    ext_group = groups.find { |g| g.name == "ext" }

    if ext_group
      client.add_beta_groups_to_build(build_id: build.id, beta_group_ids: [ext_group.id])
      UI.success("Build #{build.version} added to 'ext' External Testing group!")

      # Submit for Beta App Review (required for External Testing)
      begin
        existing_beta_subs = client.get_beta_app_review_submissions(filter: { build: build.id }).to_models
        if existing_beta_subs.empty?
          # Expire any previous builds that might block beta review.
          _expire_previous_beta_builds(client, app, build.id)

          client.post_beta_app_review_submissions(build_id: build.id)
          UI.success("Beta App Review submitted for build #{build.version}!")
        else
          UI.message("Beta App Review already exists: #{existing_beta_subs.first.beta_review_state}")
        end
      rescue => e
        UI.error("Beta App Review submission failed: #{e.message}")
      end
    else
      UI.message("'ext' beta group not found, distributing via pilot...")
      pilot(
        api_key: api_key,
        skip_waiting_for_build_processing: true,
        skip_submission: false,
        distribute_only: true,
        build_number: build.version,
        changelog: "Bug fixes and stability improvements."
      )
    end
  rescue => e
    UI.message("External Testing: #{e.message}")
  end

  # Developer-reject any pending App Store version to unblock a new submission.
  #
  # App Store states that block a new submission:
  #   READY_FOR_REVIEW   → remove review submission items to revert to PREPARE_FOR_SUBMISSION
  #   WAITING_FOR_REVIEW → developer reject: DELETE the appStoreVersionSubmission
  #   IN_REVIEW          → developer reject: DELETE the appStoreVersionSubmission
  #   PENDING_DEVELOPER_RELEASE → already approved, cannot reject
  def _reject_pending_version(client, app)
    versions = app.get_app_store_versions
    changed = false

    versions.each do |ver|
      next unless ver.platform == "IOS"
      state = ver.app_store_state
      next unless state

      case state
      when "READY_FOR_REVIEW"
        UI.message("Version #{ver.version_string} (#{ver.id}) is READY_FOR_REVIEW — removing from review submission...")
        # Remove the version's review submission items to revert to PREPARE_FOR_SUBMISSION.
        # Spaceship doesn't have delete_review_submission_item, use raw API.
        submissions = client.get_review_submissions(app_id: app.id).to_models
        submissions.each do |sub|
          next if sub.state == "COMPLETE"
          begin
            sub_items = client.get_review_submission_items(review_submission_id: sub.id).to_models
            sub_items.each do |item|
              begin
                client.tunes_request_client.delete("v1/reviewSubmissionItems/#{item.id}")
                UI.success("  Removed submission item #{item.id} from submission #{sub.id}")
                changed = true
              rescue => e
                UI.message("  Remove item #{item.id}: #{e.message}")
              end
            end
          rescue => e
            UI.message("  Get items for #{sub.id}: #{e.message}")
          end
        end

      when "WAITING_FOR_REVIEW", "IN_REVIEW"
        UI.message("Version #{ver.version_string} (#{ver.id}) is #{state} — developer rejecting...")
        # Developer reject = DELETE the appStoreVersionSubmission.
        # Use raw API since Spaceship may not expose this.
        begin
          url = "v1/appStoreVersions/#{ver.id}/appStoreVersionSubmission"
          resp = client.tunes_request_client.get(url)
          sub_data = resp.body['data']
          if sub_data && sub_data['id']
            client.tunes_request_client.delete("v1/appStoreVersionSubmissions/#{sub_data['id']}")
            UI.success("  Developer rejected version #{ver.version_string} (deleted submission #{sub_data['id']})")
            changed = true
          else
            UI.message("  No appStoreVersionSubmission found for #{ver.version_string}")
          end
        rescue => e
          UI.message("  Developer reject: #{e.message}")
        end
      end
    end

    if changed
      UI.message("Waiting 10s for App Store Connect to process...")
      sleep 10
    else
      UI.message("No pending versions to reject")
    end
  end

  def _submit_build_for_review(client, app, build)
    v = version_str
    UI.user_error!("Could not read version") if v.empty?
    UI.message("Version: #{v}")

    # 1. Find or create IOS version
    ios_version = app.get_edit_app_store_version(platform: Spaceship::ConnectAPI::Platform::IOS)
    if ios_version.nil?
      versions = app.get_app_store_versions
      ios_version = versions.find { |ver| ver.platform == "IOS" && ver.app_store_state == "PREPARE_FOR_SUBMISSION" }
    end
    if ios_version.nil?
      UI.message("Creating iOS version #{v}...")
      client.post_app_store_version(app_id: app.id, attributes: { platform: Spaceship::ConnectAPI::Platform::IOS, versionString: v })
      ios_version = app.get_edit_app_store_version(platform: Spaceship::ConnectAPI::Platform::IOS)
      # Cleanup stale MAC_OS version if it blocks us
      versions = app.get_app_store_versions
      mac = versions&.find { |ver| ver.platform == "MAC_OS" }
      if mac
        begin
          client.tunes_request_client.delete("v1/appStoreVersions/#{mac.id}")
        rescue
          nil
        end
      end
    end
    UI.user_error!("No editable iOS version") if ios_version.nil?
    if ios_version.version_string != v
      client.patch_app_store_version(app_store_version_id: ios_version.id, attributes: { versionString: v })
    end
    UI.success("Version: #{v} (#{ios_version.id})")

    # 2. Associate build
    ios_version.select_build(build_id: build.id)
    UI.success("Build associated")

    # 3. Set What's New (required by App Store) for ALL locales
    whats_new_text = "Bug fixes and stability improvements."
    begin
      localizations = ios_version.get_app_store_version_localizations
      existing_locales = localizations.map(&:locale).to_set

      # Metadata directories define the full set of locales we support
      metadata_dir = File.expand_path("metadata", __dir__)
      metadata_locales = Dir.entries(metadata_dir)
        .select { |d| d =~ /\A[a-z]{2}(-[A-Za-z]+)?\z/ }

      all_locales = (existing_locales + metadata_locales).to_set

      all_locales.each do |locale|
        loc = localizations.find { |l| l.locale == locale }
        if loc
          loc.update(attributes: { whatsNew: whats_new_text })
        else
          ios_version.create_app_store_version_localization(
            attributes: { locale: locale, whatsNew: whats_new_text }
          )
          localizations = ios_version.get_app_store_version_localizations
        end
      end

      # Verify at least one locale has What's New set
      verify_locs = ios_version.get_app_store_version_localizations
      any_set = verify_locs.any? { |l| !l.whats_new.nil? && !l.whats_new.empty? }
      unless any_set
        UI.user_error!("What's New verification failed — no locale has it set. Aborting submission.")
      end
      UI.success("What's New set for #{verify_locs.size} locales")
    rescue => e
      UI.user_error!("Failed to set What's New: #{e.message}. Aborting submission — App Store will reject without it.")
    end

    # 4. Set review notes
    begin
      review_detail = ios_version.fetch_app_store_review_detail
      review_attrs = {
        contactEmail: "support@ggcode.dev",
        contactFirstName: "Guang",
        contactLastName: "Guang",
        contactPhone: "+8613858128966",
        notes: "This app is a remote control client for GGCode, an AI coding agent that runs on macOS/Linux/Windows desktop. The mobile app connects to the desktop agent via QR code.\n\nHow to test:\n1. Install GGCode desktop app on a Mac/PC from https://ggcode.dev\n2. Start GGCode desktop\n   - GUI: click the Share button in the sidebar to generate a QR code\n   - Terminal (TUI): type /share or /tunnel in the chat to generate a QR code\n3. Open this mobile app and scan the QR code\n4. Once connected, you can chat with the AI agent, review and approve tool calls, and monitor sub-agent tasks in real-time\n\nThe app requires an active GGCode desktop session to function. No separate account or login is needed."
      }
      if review_detail
        review_detail.update(attributes: review_attrs)
      else
        ios_version.create_app_store_review_detail(attributes: review_attrs)
      end
      UI.success("Review notes set")
    rescue => e
      UI.error("Review notes: #{e.message}")
    end

    # 4. Submit — find usable submission or create new one
    submissions = client.get_review_submissions(app_id: app.id).to_models
    # Find a submission that's empty (ready for items) or create a new one.
    # After _cancel_pending_review, old submissions should be COMPLETE or gone.
    usable = submissions.find { |s| s.state.nil? || s.state.empty? }

    if usable
      UI.message("Adding version to existing submission #{usable.id}...")
      client.post_review_submission_item(review_submission_id: usable.id, app_store_version_id: ios_version.id)
      UI.success("Submitted #{usable.id}!")
    else
      UI.message("Creating new submission...")
      resp = client.post_review_submission(app_id: app.id, platform: Spaceship::ConnectAPI::Platform::IOS)
      sub = resp.to_models.first
      UI.user_error!("Failed to create review submission") if sub.nil?
      client.post_review_submission_item(review_submission_id: sub.id, app_store_version_id: ios_version.id)
      UI.success("Submitted #{sub.id} with version #{v}!")
    end
  end

  # ── Debug ─────────────────────────────────────────────

  desc "Show App Store Connect state"
  lane :inspect do
    api_key
    client = Spaceship::ConnectAPI.client
    app = Spaceship::ConnectAPI::App.find(app_id)
    UI.message("App: #{app.name}")

    versions = app.get_app_store_versions
    UI.message("App Store Versions:")
    versions.each { |v| UI.message("  #{v.version_string} | #{v.app_store_state} | #{v.platform} | #{v.id}") }

    submissions = client.get_review_submissions(app_id: app.id).to_models
    UI.message("Review Submissions (#{submissions.size}):")
    submissions.each { |s| UI.message("  #{s.id} | #{s.state}") }

    # Beta groups & builds
    groups = client.get_beta_groups(filter: { app: app.id }).to_models
    UI.message("Beta Groups (#{groups.size}):")
    groups.each do |g|
      UI.message("  #{g.name} | #{g.is_internal_group ? 'Internal' : 'External'} | #{g.id}")
    end

    builds = client.get_builds(
      filter: { app: app.id },
      sort: "-uploadedDate", limit: 3,
      includes: Spaceship::ConnectAPI::Build::ESSENTIAL_INCLUDES
    ).to_models
    UI.message("Recent Builds (#{builds.size}):")
    builds.each do |b|
      UI.message("  #{b.version} | #{b.processing_state} | #{b.id}")
    end

    # Check beta app review submissions for latest build
    begin
      latest = builds.first
      if latest
        beta_subs = client.get_beta_app_review_submissions(filter: { build: latest.id }).to_models
        UI.message("Beta App Review (build #{latest.version}):")
        if beta_subs.empty?
          UI.message("  NO beta review submission found!")
        else
          beta_subs.each { |s| UI.message("  #{s.id} | #{s.beta_review_state}") }
        end
      end
    rescue => e
      UI.message("Beta submissions: #{e.message}")
    end
  end
end
