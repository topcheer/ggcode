# iOS Fastfile for GGCode Mobile
default_platform(:ios)

platform :ios do
  desc "Upload metadata to App Store Connect (no build)"
  lane :upload_metadata do
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_KEY_ID"],
      issuer_id: ENV["APP_STORE_ISSUER_ID"],
      key_filepath: ENV["APP_STORE_KEY_PATH"] || File.expand_path("../../../secrets/AuthKey_8KNYUZ47F2.p8", __FILE__),
      in_house: false
    )

    deliver(
      api_key: api_key,
      skip_binary_upload: true,
      skip_screenshots: false,
      screenshots_path: "./metadata/en-US/screenshots",
      submit_for_review: false,
      force: true,
      precheck_include_in_app_purchases: false,
      overwrite_screenshots: true
    )
  end

  desc "Generate provisioning profiles via sigh"
  lane :provision do
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_KEY_ID"],
      issuer_id: ENV["APP_STORE_ISSUER_ID"],
      key_filepath: ENV["APP_STORE_KEY_PATH"] || File.expand_path("../../../secrets/AuthKey_8KNYUZ47F2.p8", __FILE__),
      in_house: false
    )
    sigh(
      api_key: api_key,
      app_identifier: "gg.ai.ggcode.mobile"
    )
  end

  desc "Build iOS Release Archive"
  lane :build do
    gym(
      scheme: "Runner",
      configuration: "Release",
      export_method: "app-store",
      output_directory: "../../builds/ios",
      output_name: "GGCode.ipa"
    )
  end

  desc "Upload to TestFlight (uses flutter-built IPA if available)"
  lane :upload_testflight do
    setup_ci

    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_KEY_ID"],
      issuer_id: ENV["APP_STORE_ISSUER_ID"],
      key_filepath: ENV["APP_STORE_KEY_PATH"] || File.expand_path("../../../secrets/AuthKey_8KNYUZ47F2.p8", __FILE__),
      in_house: false
    )

    sigh(
      api_key: api_key,
      app_identifier: "gg.ai.ggcode.mobile"
    )

    # Use flutter-built IPA if available (has correct version from pubspec.yaml)
    flutter_ipa = File.expand_path("../../build/ios/ipa/GGCode Mobile.ipa", __FILE__)
    if File.exist?(flutter_ipa)
      UI.message("Using flutter-built IPA: #{flutter_ipa}")
      upload_to_testflight(
        api_key: api_key,
        ipa: flutter_ipa,
        skip_waiting_for_build_processing: true,
        skip_submission: true,
        distribute_only: false
      )
    else
      UI.message("No flutter IPA found, building with gym...")
      gym(
        scheme: "Runner",
        configuration: "Release",
        export_method: "app-store",
        output_directory: "../../builds/ios",
        output_name: "GGCode.ipa",
        export_options: {
          signingStyle: "automatic"
        }
      )
      upload_to_testflight(
        api_key: api_key,
        skip_waiting_for_build_processing: true,
        skip_submission: true,
        distribute_only: false
      )
    end
  end

  desc "Upload pre-built IPA to TestFlight (no build step)"
  lane :upload_ipa do |options|
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_KEY_ID"],
      issuer_id: ENV["APP_STORE_ISSUER_ID"],
      key_filepath: ENV["APP_STORE_KEY_PATH"] || File.expand_path("../../../secrets/AuthKey_8KNYUZ47F2.p8", __FILE__),
      in_house: false
    )

    ipa_path = options[:ipa] || File.expand_path("../../build/ios/ipa/GGCode Mobile.ipa", __FILE__)
    UI.user_error!("IPA not found at #{ipa_path}") unless File.exist?(ipa_path)

    upload_to_testflight(
      api_key: api_key,
      ipa: ipa_path,
      skip_waiting_for_build_processing: true,
      skip_submission: true,
      distribute_only: false
    )
  end

  desc "Wait for TestFlight build processing, then distribute to External Testing"
  lane :promote_external do
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_KEY_ID"],
      issuer_id: ENV["APP_STORE_ISSUER_ID"],
      key_filepath: ENV["APP_STORE_KEY_PATH"] || File.expand_path("../../../secrets/AuthKey_8KNYUZ47F2.p8", __FILE__),
      in_house: false
    )

    # pilot with skip_submission=false will wait for processing and distribute
    UI.message("Waiting for TestFlight build processing and distributing to External Testing...")
    begin
      pilot(
        api_key: api_key,
        skip_waiting_for_build_processing: false,
        skip_submission: false,
        distribute_only: true,
        changelog: "Bug fixes and dependency updates"
      )
      UI.success("Build distributed to External Testing!")
    rescue => e
      UI.error("Could not auto-distribute: #{e.message}")
      UI.message("Build is available in TestFlight. Promote manually from App Store Connect.")
    end
  end

  desc "Full deploy: upload TestFlight + promote to External Testing"
  lane :deploy_external do
    upload_testflight
    promote_external
  end

  desc "Submit latest TestFlight build for App Store Review (no rebuild)"
  lane :release_latest do
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_KEY_ID"],
      issuer_id: ENV["APP_STORE_ISSUER_ID"],
      key_filepath: ENV["APP_STORE_KEY_PATH"] || File.expand_path("../../../secrets/AuthKey_8KNYUZ47F2.p8", __FILE__),
      in_house: false
    )

    # Read version from Info.plist
    plist_path = File.expand_path("../../Runner/Info.plist", __FILE__)
    version_str = `/usr/libexec/PlistBuddy -c 'Print :CFBundleShortVersionString' '#{plist_path}' 2>/dev/null`.strip
    UI.user_error!("Could not read version from Info.plist") if version_str.empty?
    UI.message("Submitting version #{version_str} for App Store Review...")

    # Ensure version exists on App Store Connect and select latest build
    begin
      app = Spaceship::ConnectAPI::App.find("gg.ai.ggcode.mobile")
      UI.user_error!("App not found on App Store Connect") if app.nil?

      # Ensure version exists (creates if needed)
      UI.message("Ensuring version #{version_str} exists on App Store Connect...")
      app.ensure_version!(version_str, platform: Spaceship::ConnectAPI::Platform::IOS)

      version = app.get_edit_app_store_version(platform: Spaceship::ConnectAPI::Platform::IOS)
      UI.user_error!("Could not get edit version for #{version_str}") if version.nil?
      UI.message("App Store version: #{version.version_string}")

      # Select the latest processed build
      builds = version.get_builds.sort_by { |b| b.build_version.to_i }.reverse
      if builds.empty?
        UI.user_error!("No builds found for version #{version_str}. Upload a build first.")
      end
      latest_build = builds.first
      UI.message("Selecting build #{latest_build.version} (#{latest_build.build_version})")
      version.select_build(build_id: latest_build.id)

      # Update review information
      app_info = app.fetch_edit_app_info
      if app_info
        app_info.update(
          app_review_information: {
            first_name: "GGCode",
            last_name: "Team",
            email: "support@ggcode.dev",
            phone: "+86",
            notes: "This app is a remote control client for GGCode, an AI coding agent that runs on macOS/Linux/Windows desktop. The mobile app connects to the desktop agent via QR code.\n\nHow to test:\n1. Install GGCode desktop app on a Mac/PC from https://ggcode.dev\n2. Start GGCode desktop\n   - GUI: click the Share button in the sidebar to generate a QR code\n   - Terminal (TUI): type /share or /tunnel in the chat to generate a QR code\n3. Open this mobile app and scan the QR code\n4. Once connected, you can chat with the AI agent, review and approve tool calls, and monitor sub-agent tasks in real-time\n\nThe app requires an active GGCode desktop session to function. No separate account or login is needed."
          }
        )
      end

      # Submit for review
      submission = app.create_review_submission(platform: Spaceship::ConnectAPI::Platform::IOS)
      UI.success("Version #{version_str} submitted for App Store Review!")
    rescue => e
      UI.error("Submit failed: #{e.message}")
      UI.message("You can manually submit from App Store Connect.")
    end
  end

  # ── Debug: inspect App Store Connect state ────────────

  desc "Test: update version string and associate build"
  lane :test_build_association do
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_KEY_ID"],
      issuer_id: ENV["APP_STORE_ISSUER_ID"],
      key_filepath: ENV["APP_STORE_KEY_PATH"] || File.expand_path("../../../secrets/AuthKey_8KNYUZ47F2.p8", __FILE__),
      in_house: false
    )

    # Read version from Info.plist
    plist_path = File.expand_path("../../Runner/Info.plist", __FILE__)
    version_str = `/usr/libexec/PlistBuddy -c 'Print :CFBundleShortVersionString' '#{plist_path}' 2>/dev/null`.strip
    UI.message("Local version: #{version_str}")

    app = Spaceship::ConnectAPI::App.find("gg.ai.ggcode.mobile")
    client = Spaceship::ConnectAPI.client

    # 1. Get the version on ASC
    versions = app.get_app_store_versions
    version = versions.find { |v| v.app_store_state == "PREPARE_FOR_SUBMISSION" }
    
    # Check platform — must be IOS
    mac_version = versions.find { |v| v.platform == "MAC_OS" }
    ios_version = versions.find { |v| v.platform == "IOS" }

    if ios_version.nil?
      # Create iOS version first (can't delete MAC_OS until another platform exists)
      UI.message("No iOS version found. Creating iOS version #{version_str}...")
      client.post_app_store_version(
        app_id: app.id,
        attributes: {
          platform: Spaceship::ConnectAPI::Platform::IOS,
          versionString: version_str
        }
      )
      ios_version = app.get_edit_app_store_version(platform: Spaceship::ConnectAPI::Platform::IOS)
      UI.user_error!("Failed to create iOS version") if ios_version.nil?
      UI.success("Created iOS version: #{ios_version.version_string}")

      # Now delete the MAC_OS version
      if mac_version
        UI.message("Deleting MAC_OS version #{mac_version.version_string}...")
        begin
          client.tunes_request_client.delete("v1/appStoreVersions/#{mac_version.id}")
          UI.success("Deleted MAC_OS version")
        rescue => e
          UI.message("Could not delete MAC_OS version: #{e.message}")
        end
      end
    end

    version = ios_version
    UI.user_error!("No editable iOS version") if version.nil?
    UI.message("ASC version: #{version.version_string} id=#{version.id} platform=#{version.platform}")

    # 3. Find latest valid build
    builds = client.get_builds(filter: { app: app.id }, sort: "-uploadedDate", limit: 10, includes: Spaceship::ConnectAPI::Build::ESSENTIAL_INCLUDES).to_models
    valid = builds.select { |b| b.processing_state == "VALID" }
    UI.user_error!("No VALID builds") if valid.empty?
    build = valid.first
    UI.message("Build: #{build.version} (#{build.id}) state=#{build.processing_state} platform=#{begin; build.platform; rescue; 'unknown'; end}")

    # 4. Associate build to version
    UI.message("Associating build #{build.version} to version #{version_str}...")
    version.select_build(build_id: build.id)
    UI.success("Build associated!")
  end

  desc "List and cancel all pending review submissions"
  lane :cleanup_submissions do
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_KEY_ID"],
      issuer_id: ENV["APP_STORE_ISSUER_ID"],
      key_filepath: ENV["APP_STORE_KEY_PATH"] || File.expand_path("../../../secrets/AuthKey_8KNYUZ47F2.p8", __FILE__),
      in_house: false
    )

    app = Spaceship::ConnectAPI::App.find("gg.ai.ggcode.mobile")
    UI.user_error!("App not found") if app.nil?

    client = Spaceship::ConnectAPI.client
    resp = client.get_review_submissions(app_id: app.id)
    submissions = resp.to_models
    UI.message("Found #{submissions.size} review submissions")

    submissions.each do |s|
      UI.message("  Submission #{s.id}: state=#{s.state}")
      begin
        client.tunes_request_client.delete("v1/reviewSubmissions/#{s.id}")
        UI.success("  Deleted #{s.id}")
      rescue => e
        UI.error("  Failed to delete #{s.id}: #{e.message}")
      end
    end

    UI.success("Cleanup done")
  end

  desc "Show all versions and builds on App Store Connect"
  lane :inspect do
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_KEY_ID"],
      issuer_id: ENV["APP_STORE_ISSUER_ID"],
      key_filepath: ENV["APP_STORE_KEY_PATH"] || File.expand_path("../../../secrets/AuthKey_8KNYUZ47F2.p8", __FILE__),
      in_house: false
    )

    app = Spaceship::ConnectAPI::App.find("gg.ai.ggcode.mobile")
    UI.user_error!("App not found") if app.nil?
    UI.message("App: #{app.name}")

    versions = app.get_app_store_versions
    versions.each do |v|
      UI.message("  Version: \"#{v.version_string}\" State: #{v.app_store_state} ID: #{v.id} Platform: #{v.platform}")
    end

    client = Spaceship::ConnectAPI.client
    submissions = client.get_review_submissions(app_id: app.id).to_models
    UI.message("Submissions (#{submissions.size}):")
    submissions.each do |s|
      UI.message("  #{s.id}: state=#{s.state}")
    end
  end

  desc "Remove invalid 'live' version from App Store Connect"
  lane :cleanup_live do
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_KEY_ID"],
      issuer_id: ENV["APP_STORE_ISSUER_ID"],
      key_filepath: ENV["APP_STORE_KEY_PATH"] || File.expand_path("../../../secrets/AuthKey_8KNYUZ47F2.p8", __FILE__),
      in_house: false
    )

    app = Spaceship::ConnectAPI::App.find("gg.ai.ggcode.mobile")
    UI.user_error!("App not found") if app.nil?

    versions = app.get_app_store_versions
    versions.each do |v|
      if v.version_string == "live"
        UI.message("Deleting invalid version \"live\" (id=#{v.id})...")
        client = Spaceship::ConnectAPI.client
        client.tunes_request_client.delete("v1/appStoreVersions/#{v.id}")
        UI.success("Deleted!")
      end
    end
  end

  desc "Full setup: ensure version, associate build, set review notes, upload metadata+screenshots, submit"
  lane :full_release do
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_KEY_ID"],
      issuer_id: ENV["APP_STORE_ISSUER_ID"],
      key_filepath: ENV["APP_STORE_KEY_PATH"] || File.expand_path("../../../secrets/AuthKey_8KNYUZ47F2.p8", __FILE__),
      in_house: false
    )

    # Read version from Info.plist
    plist_path = File.expand_path("../../Runner/Info.plist", __FILE__)
    version_str = `/usr/libexec/PlistBuddy -c 'Print :CFBundleShortVersionString' '#{plist_path}' 2>/dev/null`.strip
    UI.user_error!("Could not read version from Info.plist") if version_str.empty?
    UI.message("Local version: #{version_str}")

    app = Spaceship::ConnectAPI::App.find("gg.ai.ggcode.mobile")
    UI.user_error!("App not found") if app.nil?
    client = Spaceship::ConnectAPI.client

    # ── Step 1: Find or create IOS version ───────────────
    UI.message("Step 1: Ensuring iOS version #{version_str}...")
    versions = app.get_app_store_versions
    ios_version = versions.find { |v| v.platform == "IOS" && v.app_store_state == "PREPARE_FOR_SUBMISSION" }

    if ios_version.nil?
      UI.message("Creating iOS version #{version_str}...")
      client.post_app_store_version(
        app_id: app.id,
        attributes: { platform: Spaceship::ConnectAPI::Platform::IOS, versionString: version_str }
      )
      ios_version = app.get_edit_app_store_version(platform: Spaceship::ConnectAPI::Platform::IOS)

      # Delete stale MAC_OS version if it blocks us
      mac_version = versions.find { |v| v.platform == "MAC_OS" }
      if mac_version
        UI.message("Cleaning up MAC_OS version...")
        begin
          client.tunes_request_client.delete("v1/appStoreVersions/#{mac_version.id}")
          UI.success("Deleted MAC_OS version")
        rescue => e
          UI.message("MAC_OS cleanup skipped: #{e.message}")
        end
      end
    end

    UI.user_error!("No editable iOS version") if ios_version.nil?

    # Update version string if needed
    if ios_version.version_string != version_str
      UI.message("Updating version string from #{ios_version.version_string} to #{version_str}...")
      client.patch_app_store_version(app_store_version_id: ios_version.id, attributes: { versionString: version_str })
    end
    UI.success("Version: #{version_str} platform=#{ios_version.platform} id=#{ios_version.id}")

    # ── Step 2: Associate latest valid build ─────────────
    UI.message("Step 2: Associating latest build...")
    builds = client.get_builds(
      filter: { app: app.id },
      sort: "-uploadedDate",
      limit: 10,
      includes: Spaceship::ConnectAPI::Build::ESSENTIAL_INCLUDES
    ).to_models
    valid_builds = builds.select { |b| b.processing_state == "VALID" }
    UI.user_error!("No VALID builds found. Upload one first.") if valid_builds.empty?
    build = valid_builds.first
    UI.message("  Build: #{build.version} platform=#{begin; build.platform; rescue; '?'; end}")
    ios_version.select_build(build_id: build.id)
    UI.success("Build associated!")

    # ── Step 3: Set review notes ─────────────────────────
    UI.message("Step 3: Setting review notes...")
    begin
      review_detail = nil
      begin
        review_detail = ios_version.fetch_app_store_review_detail
      rescue
        nil
      end
      review_attrs = {
        contactEmail: "support@ggcode.dev",
        contactFirstName: "Guang",
        contactLastName: "Guang",
        contactPhone: "+8613858128966",
        notes: "This app is a remote control client for GGCode, an AI coding agent that runs on macOS/Linux/Windows desktop. The mobile app connects to the desktop agent via QR code.\n\nHow to test:\n1. Install GGCode desktop app on a Mac/PC from https://ggcode.dev\n2. Start GGCode desktop\n   - GUI: click the Share button in the sidebar to generate a QR code\n   - Terminal (TUI): type /share or /tunnel in the chat to generate a QR code\n3. Open this mobile app and scan the QR code\n4. Once connected, you can chat with the AI agent, review and approve tool calls, and monitor sub-agent tasks in real-time\n\nThe app requires an active GGCode desktop session to function. No separate account or login is needed."
      }
      if review_detail
        review_detail.update(attributes: review_attrs)
      else
        ios_version.create_app_store_review_detail(attributes: review_attrs)
      end
      UI.success("Review notes set")
    rescue => e
      UI.error("Review notes: #{e.message}")
    end

    # ── Step 4: Upload metadata + screenshots via deliver ─
    UI.message("Step 4: Uploading metadata + screenshots...")
    begin
      deliver(
        api_key: api_key,
        app_version: version_str,
        edit_live: false,
        skip_binary_upload: true,
        skip_screenshots: false,
        skip_metadata: false,
        submit_for_review: false,
        force: true,
        precheck_include_in_app_purchases: false,
        overwrite_screenshots: true,
        run_precheck_before_submit: false,
        skip_app_version_update: true
      )
      UI.success("Metadata + screenshots uploaded")
    rescue => e
      UI.error("Metadata upload: #{e.message}")
      UI.message("Retry 'fastlane full_release' or upload manually.")
    end

    # ── Step 5: Submit for review (one submission, never duplicate) ──
    UI.message("Step 5: Submitting for review...")
    begin
      submissions = client.get_review_submissions(app_id: app.id).to_models

      # Look for an existing submission that we can add items to
      existing = submissions.first

      if existing && existing.state == "READY_FOR_REVIEW"
        UI.message("Submission #{existing.id} already in READY_FOR_REVIEW — nothing to do.")
      elsif existing && (existing.state.nil? || existing.state.empty? || existing.state == "UNSURE")
        # Existing draft — add version to it
        UI.message("Adding version to existing submission #{existing.id}...")
        client.post_review_submission_item(review_submission_id: existing.id, app_store_version_id: ios_version.id)
        UI.success("Version added to submission #{existing.id}!")
      elsif existing
        UI.message("Existing submission #{existing.id} state=#{existing.state} — skipping submit.")
        UI.message("Manage submissions manually in App Store Connect.")
      else
        # No submissions at all — create one and add version
        UI.message("Creating review submission...")
        resp = client.post_review_submission(app_id: app.id, platform: Spaceship::ConnectAPI::Platform::IOS)
        new_sub = resp.to_models.first
        UI.message("Created submission #{new_sub.id}, adding version...")
        client.post_review_submission_item(review_submission_id: new_sub.id, app_store_version_id: ios_version.id)
        UI.success("Created and submitted #{new_sub.id} with version #{version_str}!")
      end
    rescue => e
      UI.error("Submit: #{e.message}")
      UI.message("Submit manually from App Store Connect.")
    end
  rescue => e
    UI.error("Release failed: #{e.message}")
    UI.error(e.backtrace.first(5).join("\n"))
    UI.message("Fix the issue above and retry, or do it manually from App Store Connect.")
  end

  desc "Build and submit for App Store Review"
  lane :release do
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_KEY_ID"],
      issuer_id: ENV["APP_STORE_ISSUER_ID"],
      key_filepath: ENV["APP_STORE_KEY_PATH"] || File.expand_path("../../../secrets/AuthKey_8KNYUZ47F2.p8", __FILE__),
      in_house: false
    )

    # Use flutter-built IPA if available
    flutter_ipa = File.expand_path("../../build/ios/ipa/GGCode Mobile.ipa", __FILE__)
    ipa_to_upload = nil
    if File.exist?(flutter_ipa)
      UI.message("Using flutter-built IPA: #{flutter_ipa}")
      ipa_to_upload = flutter_ipa
    else
      UI.message("No flutter IPA found, building with gym...")
      gym(
        scheme: "Runner",
        configuration: "Release",
        export_method: "app-store",
        output_directory: "../../builds/ios",
        output_name: "GGCode.ipa"
      )
    end

    retry_count = 0
    max_retries = 3

    begin
      upload_options = {
        api_key: api_key,
        skip_metadata: false,
        skip_screenshots: false,
        submit_for_review: true,
        automatic_release: false,
        force: true,
        precheck_include_in_app_purchases: false,
        submission_information: {
          add_id_info_uses_idfa: false
        },
        app_review_information: {
          first_name: "GGCode",
          last_name: "Team",
          email: "support@ggcode.dev",
          phone: "+86",
          notes: "This app is a remote control client for GGCode, an AI coding agent that runs on macOS/Linux/Windows desktop. The mobile app connects to the desktop agent via QR code.\n\nHow to test:\n1. Install GGCode desktop app on a Mac/PC from https://ggcode.dev\n2. Start GGCode desktop\n   - GUI: click the Share button in the sidebar to generate a QR code\n   - Terminal (TUI): type /share or /tunnel in the chat to generate a QR code\n3. Open this mobile app and scan the QR code\n4. Once connected, you can chat with the AI agent, review and approve tool calls, and monitor sub-agent tasks in real-time\n\nThe app requires an active GGCode desktop session to function. No separate account or login is needed."
        }
      }
      upload_options[:ipa] = ipa_to_upload if ipa_to_upload
      upload_to_app_store(upload_options)
    rescue => exception
      retry_count += 1
      if retry_count < max_retries
        UI.important("Upload failed (attempt #{retry_count}/#{max_retries}): #{exception.message}")
        sleep(10)
        retry
      else
        UI.error("Upload failed after #{max_retries} retries")
        UI.user_error!("Cannot complete upload")
      end
    end
  end
end
