# iOS Fastfile for GGCode Mobile
default_platform(:ios)

platform :ios do
  desc "Upload metadata to App Store Connect (no build)"
  lane :upload_metadata do
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_KEY_ID"],
      issuer_id: ENV["APP_STORE_ISSUER_ID"],
      key_filepath: ENV["APP_STORE_KEY_PATH"] || File.expand_path("../../../secrets/AuthKey_8KNYUZ47F2.p8", __FILE__),
      in_house: false
    )

    deliver(
      api_key: api_key,
      skip_binary_upload: true,
      skip_screenshots: false,
      screenshots_path: "./metadata/en-US/screenshots",
      submit_for_review: false,
      force: true,
      precheck_include_in_app_purchases: false,
      overwrite_screenshots: true,
      app_review_attachment_file: ""
    )
  end

  desc "Generate provisioning profiles via sigh"
  lane :provision do
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_KEY_ID"],
      issuer_id: ENV["APP_STORE_ISSUER_ID"],
      key_filepath: ENV["APP_STORE_KEY_PATH"] || File.expand_path("../../../secrets/AuthKey_8KNYUZ47F2.p8", __FILE__),
      in_house: false
    )
    sigh(
      api_key: api_key,
      app_identifier: "gg.ai.ggcode.mobile"
    )
  end

  desc "Build iOS Release Archive"
  lane :build do
    gym(
      scheme: "Runner",
      configuration: "Release",
      export_method: "app-store",
      output_directory: "../../builds/ios",
      output_name: "GGCode.ipa"
    )
  end

  desc "Upload to TestFlight (uses flutter-built IPA if available)"
  lane :upload_testflight do
    setup_ci

    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_KEY_ID"],
      issuer_id: ENV["APP_STORE_ISSUER_ID"],
      key_filepath: ENV["APP_STORE_KEY_PATH"] || File.expand_path("../../../secrets/AuthKey_8KNYUZ47F2.p8", __FILE__),
      in_house: false
    )

    sigh(
      api_key: api_key,
      app_identifier: "gg.ai.ggcode.mobile"
    )

    # Use flutter-built IPA if available (has correct version from pubspec.yaml)
    flutter_ipa = File.expand_path("../../build/ios/ipa/GGCode Mobile.ipa", __FILE__)
    if File.exist?(flutter_ipa)
      UI.message("Using flutter-built IPA: #{flutter_ipa}")
      upload_to_testflight(
        api_key: api_key,
        ipa: flutter_ipa,
        skip_waiting_for_build_processing: true,
        skip_submission: true,
        distribute_only: false
      )
    else
      UI.message("No flutter IPA found, building with gym...")
      gym(
        scheme: "Runner",
        configuration: "Release",
        export_method: "app-store",
        output_directory: "../../builds/ios",
        output_name: "GGCode.ipa",
        export_options: {
          signingStyle: "automatic"
        }
      )
      upload_to_testflight(
        api_key: api_key,
        skip_waiting_for_build_processing: true,
        skip_submission: true,
        distribute_only: false
      )
    end
  end

  desc "Upload pre-built IPA to TestFlight (no build step)"
  lane :upload_ipa do |options|
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_KEY_ID"],
      issuer_id: ENV["APP_STORE_ISSUER_ID"],
      key_filepath: ENV["APP_STORE_KEY_PATH"] || File.expand_path("../../../secrets/AuthKey_8KNYUZ47F2.p8", __FILE__),
      in_house: false
    )

    ipa_path = options[:ipa] || File.expand_path("../../build/ios/ipa/GGCode Mobile.ipa", __FILE__)
    UI.user_error!("IPA not found at #{ipa_path}") unless File.exist?(ipa_path)

    upload_to_testflight(
      api_key: api_key,
      ipa: ipa_path,
      skip_waiting_for_build_processing: true,
      skip_submission: true,
      distribute_only: false
    )
  end

  desc "Wait for TestFlight build processing, then promote to External Testing"
  lane :promote_external do
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_KEY_ID"],
      issuer_id: ENV["APP_STORE_ISSUER_ID"],
      key_filepath: ENV["APP_STORE_KEY_PATH"] || File.expand_path("../../../secrets/AuthKey_8KNYUZ47F2.p8", __FILE__),
      in_house: false
    )

    # Wait for the latest build to finish processing
    UI.message("Waiting for TestFlight build to finish processing...")
    build = wait_for_build_processing(
      api_key: api_key,
      build_version: ENV["BUILD_NUMBER"],
      timeout_sec: 600,
      sleep_sec: 30
    )

    if build.nil?
      UI.error("No processed build found after waiting. Skipping External Testing promotion.")
      UI.error("You can manually promote later from App Store Connect → TestFlight.")
      return
    end

    UI.success("Build #{build.build_version} (#{build.train_version}) is ready!")

    # Add to external testing group
    UI.message("Adding build to External Testing group...")
    begin
      add_to_external_group = Spaceship::ConnectAPI::BetaGroup.all.find { |g| g.is_external_group }
      if add_to_external_group
        build.add_beta_groups(beta_groups: [add_to_external_group])
        UI.success("Added to External Testing group '#{add_to_external_group.name}'")
      else
        # Create external group if none exists
        UI.message("No external testing group found. Creating one...")
        app = Spaceship::ConnectAPI::App.find("gg.ai.ggcode.mobile")
        group = Spaceship::ConnectAPI::BetaGroup.create(
          app_id: app.id,
          group_name: "External Testers",
          is_external_group: true
        )
        build.add_beta_groups(beta_groups: [group])
        UI.success("Created and added to External Testing group")
      end
    rescue => e
      UI.error("Could not add to external group: #{e.message}")
      UI.message("Build is available in TestFlight. You can manually add it to external testers.")
    end
  end

  desc "Full deploy: upload TestFlight + promote to External Testing"
  lane :deploy_external do
    upload_testflight
    promote_external
  end

  desc "Build and submit for App Store Review"
  lane :release do
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_KEY_ID"],
      issuer_id: ENV["APP_STORE_ISSUER_ID"],
      key_filepath: ENV["APP_STORE_KEY_PATH"] || File.expand_path("../../../secrets/AuthKey_8KNYUZ47F2.p8", __FILE__),
      in_house: false
    )

    # Use flutter-built IPA if available
    flutter_ipa = File.expand_path("../../build/ios/ipa/GGCode Mobile.ipa", __FILE__)
    ipa_to_upload = nil
    if File.exist?(flutter_ipa)
      UI.message("Using flutter-built IPA: #{flutter_ipa}")
      ipa_to_upload = flutter_ipa
    else
      UI.message("No flutter IPA found, building with gym...")
      gym(
        scheme: "Runner",
        configuration: "Release",
        export_method: "app-store",
        output_directory: "../../builds/ios",
        output_name: "GGCode.ipa"
      )
    end

    retry_count = 0
    max_retries = 3

    begin
      upload_options = {
        api_key: api_key,
        skip_metadata: false,
        skip_screenshots: false,
        submit_for_review: true,
        automatic_release: false,
        force: true,
        precheck_include_in_app_purchases: false,
        submission_information: {
          add_id_info_uses_idfa: false
        }
      }
      upload_options[:ipa] = ipa_to_upload if ipa_to_upload
      upload_to_app_store(upload_options)
    rescue => exception
      retry_count += 1
      if retry_count < max_retries
        UI.important("Upload failed (attempt #{retry_count}/#{max_retries}): #{exception.message}")
        sleep(10)
        retry
      else
        UI.error("Upload failed after #{max_retries} retries")
        UI.user_error!("Cannot complete upload")
      end
    end
  end
end
