<?xml version="1.0" encoding="UTF-8"?>
<!-- perUser MSI: installs to LocalAppData (no admin required).
     Different UpgradeCode from perMachine — winget handles cross-scope
     migration by detecting the installed scope and managing uninstall+install.
     Same Package Name so winget matches the same PackageId. -->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package
    Name="ggcode"
    Manufacturer="GG AI Studio"
    Version="$(var.Version)"
    UpgradeCode="{B3C4D5E6-F7A8-9012-BCDE-F23456789012}"
    Language="1033"
    InstallerVersion="500"
    Scope="perUser">
    <SummaryInformation
      Description="ggcode terminal AI coding agent (user install)"
      Manufacturer="GG AI Studio"
      Keywords="Installer" />
    <MajorUpgrade DowngradeErrorMessage="A newer version of ggcode is already installed." />
    <MediaTemplate EmbedCab="yes" />
    <Feature Id="MainFeature" Title="ggcode" Level="1">
      <ComponentGroupRef Id="MainComponents" />
    </Feature>
  </Package>

  <Fragment>
    <!-- LocalAppDataFolder = C:\Users\<user>\AppData\Local -->
    <StandardDirectory Id="LocalAppDataFolder">
      <Directory Id="INSTALLFOLDER" Name="ggcode" FileSource="$(var.SourceDir)" />
    </StandardDirectory>
  </Fragment>

  <Fragment>
    <DirectoryRef Id="INSTALLFOLDER" FileSource="$(var.SourceDir)">
      <Component Id="MainExecutableComponent" Guid="*">
        <File Id="MainExecutableFile" Name="ggcode.exe" KeyPath="yes" />
        <!-- User-level PATH (not system-level) -->
        <Environment
          Id="AddInstallDirToPath"
          Name="PATH"
          Action="set"
          Part="last"
          Permanent="no"
          System="no"
          Value="[INSTALLFOLDER]" />
      </Component>
    </DirectoryRef>
  </Fragment>

  <Fragment>
    <ComponentGroup Id="MainComponents">
      <ComponentRef Id="MainExecutableComponent" />
    </ComponentGroup>
  </Fragment>
</Wix>
