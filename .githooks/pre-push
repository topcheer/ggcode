#!/usr/bin/env bash
set -euo pipefail

if [[ "${GGCODE_SKIP_CI_HOOK:-0}" == "1" ]]; then
  exit 0
fi

# Pre-push hook: run CI-aligned checks before pushing.
# This catches failures that would break GitHub Actions CI.

repo_root="$(git rev-parse --show-toplevel)"
cd "${repo_root}"

echo "[pre-push] running CI-aligned checks"
exec ./scripts/dev/verify-ci.sh
