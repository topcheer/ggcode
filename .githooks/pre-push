#!/usr/bin/env bash
set -euo pipefail

if [[ "${GGCODE_SKIP_CI_HOOK:-0}" == "1" ]]; then
  exit 0
fi

repo_root="$(git rev-parse --show-toplevel)"
cd "${repo_root}"

# Check gofmt cleanliness
unformatted=$(gofmt -l .)
if [[ -n "${unformatted}" ]]; then
  echo "[pre-push] ERROR: unformatted files:"
  echo "${unformatted}"
  echo "Run: gofmt -w <files>"
  exit 1
fi

echo "[pre-push] running go vet"
go vet -tags goolm ./...

echo "[pre-push] running go build"
CGO_ENABLED=0 go build -tags goolm -o /dev/null ./cmd/ggcode

echo "[pre-push] checks passed"

# Pull any CI-pushed commits (e.g. mobile build number bumps) to avoid
# push rejection.  Skipped when pushing tags (no remote branch to pull).
if git symbolic-ref -q HEAD >/dev/null 2>&1; then
  remote_branch="$(git rev-parse --abbrev-ref --symbolic-full-name @{u} 2>/dev/null || true)"
  if [[ -n "${remote_branch}" ]]; then
    echo "[pre-push] pulling ${remote_branch} (rebase)..."
    had_stash=false
    if ! git diff --quiet || ! git diff --cached --quiet; then
      git stash --keep-index -q
      had_stash=true
    fi
    git pull --rebase "${remote_branch%%/*}" "${remote_branch#*/}" || {
      echo "[pre-push] WARNING: git pull --rebase failed, continuing push attempt"
    }
    if [[ "${had_stash}" == true ]]; then
      git stash pop -q || true
    fi
  fi
fi

# ── Mobile version sync on release push ──────────────────
# When the top commit is a release, bump the mobile build number
# and commit it. CI will use the version already in the files.
latest_msg=$(git log -1 --format=%s)
if [[ "$latest_msg" =~ ^release:\ v([0-9]+\.[0-9]+\.[0-9]+) ]]; then
  rel_version="${BASH_REMATCH[1]}"
  sync_script="mobile/flutter/scripts/version_sync.sh"
  if [[ -f "$sync_script" ]]; then
    echo "[pre-push] release v${rel_version} detected, syncing mobile build number..."
    (cd mobile/flutter && bash scripts/version_sync.sh "$rel_version")
    git add mobile/flutter/.build-number \
            mobile/flutter/pubspec.yaml \
            mobile/flutter/android/app/build.gradle.kts \
            mobile/flutter/ios/Runner/Info.plist
    if ! git diff --cached --quiet; then
      git commit --no-verify -m "chore(mobile): bump build number for v${rel_version}"
      echo "[pre-push] build number committed"
    fi
  fi
fi
